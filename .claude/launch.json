{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:web"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:api"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "web-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--workspace=apps/web", "next", "dev", "--port", "3010"],
      "port": 3010,
      "autoPort": false
    }
  ]
}
