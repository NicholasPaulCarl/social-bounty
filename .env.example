# ─────────────────────────────────────
# Database (Supabase)
# ─────────────────────────────────────
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@YOUR_REGION.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────
# Authentication
# ─────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-256-bits
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-256-bits
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────
# Application
# ─────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────
# File Uploads
# ─────────────────────────────────────
FILE_UPLOAD_MAX_SIZE=5242880
FILE_UPLOAD_DEST=./uploads
FILE_UPLOAD_MAX_FILES=5

# ─────────────────────────────────────
# Email (SMTP — Brevo)
# ─────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=a78739001@smtp-brevo.com
SMTP_PASS=
SMTP_FROM=noreply@socialbounty.cash

# ─────────────────────────────────────
# OTP Configuration
# ─────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# ─────────────────────────────────────
# Redis
# ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────
# Error Tracking
# ─────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─────────────────────────────────────
# Frontend
# ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ─────────────────────────────────────
# Stripe (legacy — retires in Phase 3 cleanup once Stitch is prod-stable)
# ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_test_

# ─────────────────────────────────────
# Stitch Express (canonical payment gateway — md-files/payment-gateway.md)
# PAYMENTS_PROVIDER gates checkout creation:
#   none          — no new payments accepted (rollback mode)
#   stitch_sandbox — sandbox creds; safe default for dev/staging
#   stitch_live   — production creds only
# ─────────────────────────────────────
PAYMENTS_PROVIDER=stitch_sandbox
STITCH_API_BASE=https://express.stitch.money
STITCH_CLIENT_ID=
STITCH_CLIENT_SECRET=
STITCH_WEBHOOK_SECRET=
STITCH_REDIRECT_URL=http://localhost:3000/business/bounties/funded
STITCH_PAYOUT_SPEED=DEFAULT
STITCH_MIN_PAYOUT_CENTS=2000

# NOTE: `FINANCIAL_KILL_SWITCH` was removed 2026-04-15 (orphan sweep C2).
# The kill switch is a DB row (SystemSetting key `financial.kill_switch.active`),
# flipped from the Finance admin dashboard or via LedgerService.setKillSwitch.
# There is NO env-var control — setting one has no effect on payments.

# ─────────────────────────────────────
# Feature flags (validated at boot — env.validation.ts)
# ─────────────────────────────────────
# Gates PayoutsScheduler / ClearanceScheduler / (fallback) ExpiredBountyScheduler.
# Leave `false` until TradeSafe outbound rail is live (ADR 0008 / 0009).
# Valid values: `true` | `false`.
PAYOUTS_ENABLED=false

# Gates ReconciliationScheduler. Default `true`; set `false` only for drills.
RECONCILIATION_ENABLED=true

# Per-job override for ExpiredBountyScheduler. When unset, falls back to
# PAYOUTS_ENABLED. Valid values: `true` | `false` | (unset).
# EXPIRED_BOUNTY_RELEASE_ENABLED=

# ─────────────────────────────────────
# Payout beneficiary encryption (SECURITY-SENSITIVE)
# AES-256-GCM key for encrypting bank account numbers on StitchBeneficiary.
#
# REQUIRED when PAYOUTS_ENABLED=true. Minimum 32 characters — AES-256 key
# material needs ≥32 bytes of entropy; the validator will refuse to boot
# with a shorter value when payouts are live.
#
# When PAYOUTS_ENABLED=false (current pre-TradeSafe state, ADR 0008) the
# value may be left empty; BeneficiaryService falls back to a JWT_SECRET-
# derived key for dev ergonomics and logs a loud warning. Do NOT rely on
# that fallback in any env that will flip PAYOUTS_ENABLED=true — rotate
# in a dedicated key BEFORE flipping the flag, or boot will fail (R29,
# audit batch 14A 2026-04-15).
#
# Generate a strong value with:  openssl rand -base64 48
# ─────────────────────────────────────
BENEFICIARY_ENC_KEY=replace-with-32-plus-char-random-secret-before-enabling-payouts

# Users.id of the dedicated system-actor row used as the fallback AuditLog
# actor when a ledger write originates from a webhook or scheduled job with
# no user in context. AuditLog.actorId has a FK to users.id so this must
# point at a real row. Seed via:
#   INSERT INTO users (id, email, "firstName", "lastName", role, status, "emailVerified")
#   VALUES ('00000000-0000-0000-0000-000000000001',
#           'system+stitch@socialbounty.internal',
#           'System', 'Stitch', 'SUPER_ADMIN', 'ACTIVE', true)
#   ON CONFLICT (email) DO NOTHING;
STITCH_SYSTEM_ACTOR_ID=00000000-0000-0000-0000-000000000001

# ─────────────────────────────────────
# Clearance window overrides (DEV/STAGING ONLY)
# When set, ApprovalLedgerService uses these instead of the canonical
# CLEARANCE_HOURS constants (FREE=72h, PRO=0h) from @social-bounty/shared.
# This makes the approve → clearance → payout loop live-testable in seconds
# instead of waiting 72 hours. Leave UNSET in production.
# Fractional hours are allowed, e.g. 0.0083 ≈ 30 seconds.
# ─────────────────────────────────────
# CLEARANCE_OVERRIDE_HOURS_FREE=0.0083
# CLEARANCE_OVERRIDE_HOURS_PRO=0

# ─────────────────────────────────────
# Apify (social analytics scraping)
# Leave blank to disable; frontend falls back to deterministic mock.
# ─────────────────────────────────────
APIFY_API_TOKEN=
APIFY_ACTOR_TIMEOUT_MS=60000
