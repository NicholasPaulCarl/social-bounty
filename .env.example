# ─────────────────────────────────────
# Database
# ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_bounty?schema=public

# ─────────────────────────────────────
# Authentication
# ─────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-256-bits
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-256-bits
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────
# Application
# ─────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────
# File Uploads
# ─────────────────────────────────────
FILE_UPLOAD_MAX_SIZE=5242880
FILE_UPLOAD_DEST=./uploads
FILE_UPLOAD_MAX_FILES=5

# ─────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@socialbounty.com

# ─────────────────────────────────────
# Error Tracking
# ─────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─────────────────────────────────────
# Frontend
# ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
