{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "tsConfigPath": "tsconfig.build.json",
    "deleteOutDir": false,
    "builder": "tsc",
    "assets": [
      {
        "include": "modules/mail/templates/**/*.hbs",
        "watchAssets": true
      }
    ]
  }
}
