<h2 style="margin:0 0 16px;font-size:20px;color:#1a1a2e;">
  Payout Notification
</h2>

<p style="margin:0 0 12px;font-size:15px;color:#333333;line-height:1.6;">
  Hi {{userName}},
</p>

<p style="margin:0 0 16px;font-size:15px;color:#333333;line-height:1.6;">
  Great news! A payout has been processed for your approved submission on
  <strong>"{{bountyTitle}}"</strong>.
</p>

<!-- Payout Amount -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
  <tr>
    <td style="padding:20px;background-color:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;text-align:center;">
      <p style="margin:0 0 4px;font-size:13px;color:#666666;text-transform:uppercase;font-weight:600;">
        Amount Paid
      </p>
      <p style="margin:0;font-size:28px;color:#16a34a;font-weight:700;">
        {{currency}} {{amount}}
      </p>
    </td>
  </tr>
</table>

<p style="margin:0 0 8px;font-size:15px;color:#333333;line-height:1.6;">
  The funds should appear in your account according to the payment method on file.
  If you have questions about this payout, please contact support.
</p>

<p style="margin:16px 0 0;font-size:13px;color:#999999;">
  Thank you for participating in Social Bounty!
</p>
