{
  "$schema": "https://design-tokens.org/schema.json",
  "_meta": {
    "name": "Social Bounty",
    "version": "1.0.0",
    "description": "Design tokens for the Social Bounty creator-economy product. Mirror of colors_and_type.css for design-tool sync (Figma Tokens, Style Dictionary)."
  },

  "color": {
    "pink": {
      "50":  { "$value": "#fdf2f8", "$type": "color" },
      "100": { "$value": "#fce7f3", "$type": "color" },
      "200": { "$value": "#fbcfe8", "$type": "color" },
      "300": { "$value": "#f9a8d4", "$type": "color" },
      "400": { "$value": "#f472b6", "$type": "color" },
      "500": { "$value": "#ec4899", "$type": "color" },
      "600": { "$value": "#db2777", "$type": "color", "$description": "★ Brand. Primary buttons, links, focus, eyebrows." },
      "700": { "$value": "#be185d", "$type": "color", "$description": "Brand hover." },
      "800": { "$value": "#9d174d", "$type": "color" },
      "900": { "$value": "#831843", "$type": "color" }
    },
    "blue": {
      "50":  { "$value": "#eff6ff", "$type": "color" },
      "100": { "$value": "#dbeafe", "$type": "color" },
      "500": { "$value": "#3b82f6", "$type": "color" },
      "600": { "$value": "#2563eb", "$type": "color", "$description": "★ Gradient partner only. Never standalone." },
      "700": { "$value": "#1d4ed8", "$type": "color" }
    },
    "slate": {
      "50":  { "$value": "#f8fafc", "$type": "color" },
      "100": { "$value": "#f1f5f9", "$type": "color" },
      "200": { "$value": "#e2e8f0", "$type": "color" },
      "300": { "$value": "#cbd5e1", "$type": "color" },
      "400": { "$value": "#94a3b8", "$type": "color" },
      "500": { "$value": "#64748b", "$type": "color" },
      "600": { "$value": "#475569", "$type": "color" },
      "700": { "$value": "#334155", "$type": "color" },
      "800": { "$value": "#1e293b", "$type": "color" },
      "900": { "$value": "#0f172a", "$type": "color" }
    },
    "success": { "500": { "$value": "#22c55e", "$type": "color" }, "600": { "$value": "#16a34a", "$type": "color" }, "700": { "$value": "#15803d", "$type": "color" } },
    "warning": { "500": { "$value": "#f59e0b", "$type": "color" }, "600": { "$value": "#d97706", "$type": "color" }, "700": { "$value": "#b45309", "$type": "color" } },
    "danger":  { "500": { "$value": "#f43f5e", "$type": "color" }, "600": { "$value": "#e11d48", "$type": "color" }, "700": { "$value": "#be123c", "$type": "color" } },
    "reward":  { "500": { "$value": "#f59e0b", "$type": "color", "$description": "Gold. Reserved for earnings/points/streaks. Never on interactive." }, "600": { "$value": "#d97706", "$type": "color" } }
  },

  "gradient": {
    "signature": {
      "$value": "linear-gradient(90deg, {color.pink.600}, {color.blue.600})",
      "$type": "gradient",
      "$description": "Use ONCE per view. Headings, progress bars, marketing CTA pill."
    }
  },

  "fontFamily": {
    "heading": { "$value": "'Space Grotesk', system-ui, sans-serif", "$type": "fontFamily" },
    "body":    { "$value": "'Inter', system-ui, sans-serif", "$type": "fontFamily" },
    "mono":    { "$value": "'JetBrains Mono', ui-monospace, monospace", "$type": "fontFamily" }
  },
  "fontSize": {
    "xs":  { "$value": "12px", "$type": "dimension" },
    "sm":  { "$value": "14px", "$type": "dimension" },
    "md":  { "$value": "16px", "$type": "dimension" },
    "lg":  { "$value": "18px", "$type": "dimension" },
    "xl":  { "$value": "20px", "$type": "dimension" },
    "2xl": { "$value": "24px", "$type": "dimension" },
    "3xl": { "$value": "30px", "$type": "dimension" },
    "4xl": { "$value": "36px", "$type": "dimension" },
    "5xl": { "$value": "48px", "$type": "dimension" },
    "6xl": { "$value": "60px", "$type": "dimension" },
    "7xl": { "$value": "72px", "$type": "dimension" }
  },
  "fontWeight": {
    "regular":  { "$value": 400, "$type": "fontWeight" },
    "medium":   { "$value": 500, "$type": "fontWeight" },
    "semibold": { "$value": 600, "$type": "fontWeight" },
    "bold":     { "$value": 700, "$type": "fontWeight" }
  },
  "lineHeight": {
    "tight":   { "$value": 1.05, "$type": "number" },
    "snug":    { "$value": 1.2,  "$type": "number" },
    "normal":  { "$value": 1.5,  "$type": "number" },
    "relaxed": { "$value": 1.6,  "$type": "number" }
  },
  "letterSpacing": {
    "tight":  { "$value": "-0.02em", "$type": "dimension" },
    "snug":   { "$value": "-0.01em", "$type": "dimension" },
    "normal": { "$value": "0",       "$type": "dimension" },
    "wide":   { "$value": "0.05em",  "$type": "dimension" },
    "wider":  { "$value": "0.08em",  "$type": "dimension" }
  },

  "spacing": {
    "_meta": { "_unit": "4px grid", "_description": "All spacing is a multiple of 4px." },
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension", "$description": "default card padding (compact)" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension", "$description": "card padding (default)" },
    "8":  { "$value": "32px", "$type": "dimension", "$description": "feature-card padding" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension", "$description": "between sections (mobile)" },
    "16": { "$value": "64px", "$type": "dimension", "$description": "between sections (desktop)" },
    "20": { "$value": "80px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension", "$description": "hero breathing room" }
  },

  "radius": {
    "sm":   { "$value": "4px",  "$type": "dimension" },
    "md":   { "$value": "8px",  "$type": "dimension", "$description": "buttons" },
    "lg":   { "$value": "12px", "$type": "dimension" },
    "xl":   { "$value": "16px", "$type": "dimension", "$description": "cards (default)" },
    "2xl":  { "$value": "20px", "$type": "dimension" },
    "3xl":  { "$value": "24px", "$type": "dimension", "$description": "feature cards" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "pills (CTA, badges, chips)" }
  },

  "shadow": {
    "level-1": { "$value": "0 1px 2px rgba(0,0,0,0.04)", "$type": "shadow", "$description": "resting card, input" },
    "level-2": { "$value": "0 4px 8px rgba(0,0,0,0.06)", "$type": "shadow", "$description": "hover, focus" },
    "level-3": { "$value": "0 8px 24px rgba(0,0,0,0.10)", "$type": "shadow", "$description": "dropdown, popover" },
    "level-4": { "$value": "0 16px 48px rgba(0,0,0,0.14)", "$type": "shadow", "$description": "modal, dialog" },
    "brand":   { "$value": "0 8px 32px rgba(219, 39, 119, 0.40)", "$type": "shadow", "$description": "★ Primary CTA only" },
    "blue":    { "$value": "0 8px 32px rgba(37, 99, 235, 0.30)",  "$type": "shadow", "$description": "Gradient-partner uses only" }
  },

  "motion": {
    "duration": {
      "fast":     { "$value": "150ms", "$type": "duration" },
      "normal":   { "$value": "250ms", "$type": "duration" },
      "slow":     { "$value": "400ms", "$type": "duration" },
      "dramatic": { "$value": "600ms", "$type": "duration" }
    },
    "easing": {
      "standard":   { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",       "$type": "cubicBezier" },
      "decelerate": { "$value": "cubic-bezier(0, 0, 0.2, 1)",         "$type": "cubicBezier" },
      "accelerate": { "$value": "cubic-bezier(0.4, 0, 1, 1)",         "$type": "cubicBezier" },
      "spring":     { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier", "$description": "playful — reward toasts, success bursts" }
    }
  }
}
