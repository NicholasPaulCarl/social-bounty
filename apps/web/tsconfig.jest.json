{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    // ts-jest overrides moduleResolution to "node10" when it sees "bundler" in
    // the base tsconfig, which triggers TS5107. Explicitly setting "node" here
    // prevents the override (ts-jest honours an explicit value) and avoids the
    // deprecation warning since "node" is the legacy alias, not "node10".
    "moduleResolution": "node",
    // TS 6.0 is the intended deploy target (package.json pins `^6.0.2`), but
    // the installed resolution is currently 5.9.3 which only accepts "5.0".
    // Keep this in sync with whatever TS major is actually installed.
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*"]
}
