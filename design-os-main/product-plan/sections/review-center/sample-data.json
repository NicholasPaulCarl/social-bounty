{
  "_meta": {
    "models": {
      "Submission": "A participant's completed work for a specific bounty, including structured proof-of-completion. Submissions follow a review lifecycle: Submitted, In Review, Needs More Info, Approved, Rejected.",
      "Participant": "A simplified user record representing the person who submitted work, shown in the review context.",
      "BountySummary": "A lightweight bounty reference providing context for the reviewer without loading the full bounty record.",
      "ProofItem": "An individual piece of evidence attached to a submission — text block, URL link, or uploaded image.",
      "ReviewHistoryEntry": "A timestamped record of a review action (status change, note, or info request) on a submission.",
      "Payout": "A financial record tracking payment status for an approved submission."
    },
    "relationships": [
      "Submission belongs to a BountySummary (the bounty it was submitted for)",
      "Submission belongs to a Participant (the user who submitted it)",
      "Submission has many ProofItem records as evidence of completion",
      "Submission has many ReviewHistoryEntry records forming its review timeline",
      "Submission has one optional Payout (created when approved)"
    ]
  },
