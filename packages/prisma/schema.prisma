// ─────────────────────────────────────
// Dispute Enums
// ─────────────────────────────────────

enum DisputeStatus {
  DRAFT
  OPEN
  UNDER_REVIEW
  AWAITING_RESPONSE
  ESCALATED
  RESOLVED
  CLOSED
  WITHDRAWN
}

enum DisputeCategory {
  NON_PAYMENT
  POST_QUALITY
  POST_NON_COMPLIANCE
}

enum DisputeReason {
  // Category A — Non-Payment
  PAYMENT_NOT_RECEIVED
  PAYMENT_INCORRECT_AMOUNT
  PAYMENT_DELAYED_BEYOND_TERMS
