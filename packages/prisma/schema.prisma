  DAYS
  WEEKS
}

enum Currency {
  ZAR
  USD
  GBP
  EUR
}

enum PayoutMethod {
  PAYPAL
  BANK_TRANSFER
  E_WALLET
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
}

