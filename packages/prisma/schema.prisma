  POST_REMOVED
  POST_QUALITY_BELOW_STANDARD
  POST_WRONG_PLATFORM
  POST_MISSING_REQUIRED_ELEMENTS
  // Category C — Non-Compliance After Payment
  POST_DELETED_AFTER_PAYMENT
  POST_EDITED_AFTER_PAYMENT
  DISCLOSURE_REMOVED
  COMPETITOR_CONTENT_ADDED
  TERMS_VIOLATED_AFTER_PAYMENT
}

enum DisputeResolution {
  PAYMENT_APPROVED
  PAYMENT_ADJUSTED
  PAYMENT_DENIED
  SUBMISSION_REVOKED
  RESUBMISSION_REQUIRED
  CONTENT_CORRECTION_REQUIRED
  REFUND_REQUESTED
  NO_ACTION
  MUTUAL_AGREEMENT
  DISMISSED
}

enum DisputeMessageType {
  COMMENT
  EVIDENCE
  INTERNAL_NOTE
  SYSTEM
  RESOLUTION_PROPOSAL
}

enum EvidenceType {
  SCREENSHOT
  LINK
  DOCUMENT
  OTHER
}

// ─────────────────────────────────────
// Ledger & Payment Enums
// Source: md-files/payment-gateway.md + md-files/financial-architecture.md
// Payment rail: TradeSafe (unified inbound + outbound per ADR 0011).
// ─────────────────────────────────────

enum LedgerAccount {
  brand_cash_received
  brand_reserve
  brand_refundable
  hunter_pending
  hunter_clearing
  hunter_available
  hunter_paid
  hunter_net_payable
  commission_revenue
  admin_fee_revenue
  global_fee_revenue
  processing_expense
  payout_fee_recovery
  bank_charges
  gateway_clearing
  payout_in_transit
  subscription_revenue
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

enum LedgerEntryStatus {
  PENDING
  COMPLETED
  REVERSED
}

enum WebhookProvider {
  STITCH
  STRIPE
  TRADESAFE
}

enum WebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  DUPLICATE
}

// Outbound-payout rail discriminator. Originally added for R32 so
// reconciliation could attribute "settled but no ledger group" findings
// to the correct provider. Post-ADR 0011 (single-rail TradeSafe), STITCH
// is retained as a legacy value so historical rows remain readable; no
// new rows are created with STITCH. See ADR 0011.
enum PayoutRail {
  STITCH
  TRADESAFE
}

// TradeSafe transaction-level state machine.
// Source: docs.tradesafe.co.za quick-start + mirrored in
// apps/api/src/modules/tradesafe/tradesafe-graphql.operations.ts.
// CREATED → FUNDS_RECEIVED → INITIATED → DELIVERED → FUNDS_RELEASED
// DISPUTE / CANCELLED are terminal off-ramps.
enum TradeSafeTransactionState {
  CREATED
  FUNDS_RECEIVED
  INITIATED
  DELIVERED
  FUNDS_RELEASED
  DISPUTE
  CANCELLED
}

// TradeSafe allocation-level state machine. Mirrors TransactionState today
// but kept as a distinct enum so the two state machines can diverge later
// (TradeSafe's GraphQL treats them as separate types). Same values.
enum TradeSafeAllocationState {
  CREATED
  FUNDS_RECEIVED
  INITIATED
  DELIVERED
  FUNDS_RELEASED
  DISPUTE
  CANCELLED
}

enum JobRunStatus {
  STARTED
  SUCCEEDED
  FAILED
  PARTIAL
  HALTED
}

enum RefundState {
  REQUESTED
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

enum RefundScenario {
  BEFORE_APPROVAL
  AFTER_APPROVAL
  AFTER_PAYOUT
}

enum KybStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────
// Models
// ─────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  firstName         String
  lastName          String
  role              UserRole   @default(PARTICIPANT)
  status            UserStatus @default(ACTIVE)
  emailVerified     Boolean    @default(false)
  phoneNumber       String?    @unique
  phoneVerified     Boolean    @default(false)
  bio               String?    @db.VarChar(500)
  profilePictureUrl String?
  interests         Json? // string array: ["Fitness & Wellness", "Food & Cooking", ...]
  // TradeSafe party token (from `tokenCreate` mutation). Opaque string, one per
  // user. Set by TradeSafeTokenService.ensureToken on first need (signup hook
  // fire-and-forget, or blocking from the bounty-funding path in Phase 3).
  // See ADR 0011 (TradeSafe unified rail) + md-files/payment-gateway.md.
  tradeSafeTokenId  String?    @unique
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  refreshTokenAudits      RefreshTokenAudit[]
  submissions             Submission[]              @relation("UserSubmissions")
  socialLinks             SocialLink[]
  reviewedSubmissions     Submission[]              @relation("ReviewerSubmissions")
  brandMemberships        BrandMember[]
  createdBounties         Bounty[]                  @relation("BountyCreator")
  auditLogs               AuditLog[]                @relation("AuditActor")
  fileUploads             FileUpload[]              @relation("FileUploader")
  brandAssets             BrandAsset[]              @relation("BrandAssetUploader")
  filedDisputes           Dispute[]                 @relation("DisputeFiler")
  resolvedDisputes        Dispute[]                 @relation("DisputeResolver")
  assignedDisputes        Dispute[]                 @relation("DisputeAssignee")
  disputeMessages         DisputeMessage[]
  disputeEvidence         DisputeEvidence[]
  disputeStatusChanges    DisputeStatusHistory[]
  wallet                  Wallet?
  withdrawals             Withdrawal[]
  bountyApplications      BountyApplication[]       @relation("UserApplications")
  reviewedApplications    BountyApplication[]       @relation("ApplicationReviewer")
  bountyInvitations       BountyInvitation[]        @relation("UserInvitations")
  sentInvitations         BountyInvitation[]        @relation("InvitationCreator")
  userSocialHandles       UserSocialHandle[]        @relation("UserSocialHandles")
  notifications           Notification[]            @relation("UserNotifications")
  conversationsCreated    Conversation[]            @relation("ConversationsCreated")
  conversationMemberships ConversationParticipant[] @relation("ConversationParticipants")
  messagesSent            Message[]                 @relation("MessagesSent")
  subscription            Subscription?             @relation("UserSubscription")
  ledgerEntries           LedgerEntry[]
  refundsRequested        Refund[]                  @relation("RefundRequester")
  refundsApproved         Refund[]                  @relation("RefundApprover")
  refundsDualApproved     Refund[]                  @relation("RefundDualApprover")

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshTokenAudit {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti       String
  issuedAt  DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([jti])
  @@map("refresh_token_audits")
}

model Brand {
  id               String      @id @default(uuid())
  name             String
  handle           String?     @unique
  logo             String?
  coverPhotoUrl    String?
  contactEmail     String
  bio              String?     @db.VarChar(500)
  websiteUrl       String?
  socialLinks      Json? // { instagram?, tiktok?, facebook?, x?, website? }
  socialAnalytics  Json? // BrandSocialAnalyticsBlob — populated by ApifyService
  targetInterests  Json? // string[] from HUNTER_INTERESTS
  messagingEnabled Boolean     @default(true)
  status           BrandStatus @default(ACTIVE)
  kybStatus        KybStatus   @default(NOT_STARTED)
  kybSubmittedAt   DateTime?
  kybApprovedAt    DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  members       BrandMember[]
  bounties      Bounty[]
  subscription  Subscription? @relation("BrandSubscription")
  ledgerEntries LedgerEntry[]

  @@index([status])
  @@index([handle])
  // DB table name preserved to avoid a table-rename migration; the TS model
  // name is what consumers see, but the underlying table stays "organisations".
  @@map("organisations")
}

model BrandMember {
  id       String          @id @default(uuid())
  userId   String
  brandId  String          @map("organisationId")
  role     BrandMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@index([userId])
  @@index([brandId])
  @@map("organisation_members")
}

model Bounty {
  id                String       @id @default(uuid())
  brandId           String       @map("organisationId")
  createdById       String
  title             String
  shortDescription  String       @default("")
  contentFormat     String       @default("BOTH")
  fullInstructions  String       @default("") @db.Text
  instructionSteps  Json?
  category          String       @default("")
  rewardType        RewardType   @default(CASH)
  rewardValue       Decimal?     @db.Decimal(12, 2)
  rewardDescription String?
  maxSubmissions    Int?
  startDate         DateTime?
  endDate           DateTime?
  eligibilityRules  String       @default("") @db.Text
  proofRequirements String       @default("") @db.Text
  status            BountyStatus @default(DRAFT)
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // New fields for create bounty redesign
  currency               Currency            @default(ZAR)
  channels               Json?
  aiContentPermitted     Boolean             @default(false)
  engagementRequirements Json?
  postVisibilityRule     PostVisibilityRule?
  postMinDurationValue   Int?
  postMinDurationUnit    DurationUnit?
  structuredEligibility  Json?
  visibilityAcknowledged Boolean             @default(false)
  payoutMetrics          Json?
  paymentStatus          PaymentStatus       @default(UNPAID)
  payoutMethod           PayoutMethod?
  accessType             BountyAccessType    @default(PUBLIC)
  statusHistory          Json?
  adminFeePercent        Decimal?            @db.Decimal(5, 2)
  adminFeeAmount         Decimal?            @db.Decimal(18, 2)

  // Ledger snapshots (Non-Negotiable #9: plan snapshot at funding time)
  planSnapshotBrand    SubscriptionTier?
  brandAdminFeeRateBps Int?
  globalFeeRateBps     Int?
  faceValueCents       BigInt?

  // Relations
  brand                Brand                 @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdBy            User                  @relation("BountyCreator", fields: [createdById], references: [id], onDelete: Restrict)
  submissions          Submission[]
  rewards              BountyReward[]
  brandAssets          BrandAsset[]
  applications         BountyApplication[]   @relation("BountyApplications")
  invitations          BountyInvitation[]    @relation("BountyInvitations")
  tradeSafeTransaction TradeSafeTransaction?
  ledgerEntries        LedgerEntry[]
  refunds              Refund[]

  @@index([brandId])
  @@index([status])
  @@index([category])
  @@index([createdById])
  @@index([startDate, endDate])
  @@index([deletedAt])
  @@index([status, deletedAt])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([accessType])
  @@map("bounties")
}

model BountyReward {
  id            String     @id @default(uuid())
  bountyId      String
  rewardType    RewardType
  name          String     @db.VarChar(200)
  monetaryValue Decimal    @db.Decimal(12, 2)
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)

  @@index([bountyId])
  @@map("bounty_rewards")
}

model Submission {
  id                   String           @id @default(uuid())
  bountyId             String
  userId               String
  proofText            String           @db.Text
  proofLinks           Json?
  status               SubmissionStatus @default(SUBMITTED)
  reviewerNote         String?          @db.Text
  reviewedById         String?
  payoutStatus         PayoutStatus     @default(NOT_PAID)
  reportedMetrics      Json?
  verificationDeadline DateTime?
  reviewHistory        Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // Ledger snapshots (Non-Negotiable #9: plan snapshot at approval time)
  planSnapshotHunter         SubscriptionTier?
  commissionRateBps          Int?
  clearanceReleaseAt         DateTime?
  hunterNetCents             BigInt?
  transactionGroupIdApproval String?

  // Phase 2A: PostVisibility re-check scheduler. `approvedAt` drives the
  // post-age cadence buckets; `lastVisibilityCheckAt` powers the oldest-
  // first scheduler selection; `consecutiveVisibilityFailures` triggers
  // the auto-refund + email at the 2-failure threshold.
  approvedAt                    DateTime?
  lastVisibilityCheckAt         DateTime?
  consecutiveVisibilityFailures Int       @default(0)

  // Relations
  bounty             Bounty                       @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  user               User                         @relation("UserSubmissions", fields: [userId], references: [id], onDelete: Restrict)
  reviewedBy         User?                        @relation("ReviewerSubmissions", fields: [reviewedById], references: [id], onDelete: SetNull)
  proofImages        FileUpload[]
  payout             Payout?
  disputes           Dispute[]
  ledgerEntries      LedgerEntry[]
  refunds            Refund[]
  urlScrapes         SubmissionUrlScrape[]
  urlScrapeHistories SubmissionUrlScrapeHistory[]

  @@unique([bountyId, userId])
  @@index([bountyId])
  @@index([userId])
  @@index([status])
  @@index([payoutStatus])
  @@index([reviewedById])
  @@index([status, payoutStatus, verificationDeadline])
  @@index([createdAt])
  @@index([approvedAt, lastVisibilityCheckAt])
  @@map("submissions")
}

// Per-URL Apify scrape result + verification checks. One row per (submission, URL).
// APPROVED transition is blocked until all rows are VERIFIED.
// See migration 20260417120000_add_submission_url_scrapes for the DDL.
enum UrlScrapeStatus {
  PENDING
  IN_PROGRESS
  VERIFIED
  FAILED
}

model SubmissionUrlScrape {
  id                 String          @id @default(uuid())
  submissionId       String
  url                String
  channel            SocialChannel
  format             PostFormat
  scrapeStatus       UrlScrapeStatus @default(PENDING)
  scrapeResult       Json?
  verificationChecks Json?
  errorMessage       String?
  scrapedAt          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  submission Submission                   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  histories  SubmissionUrlScrapeHistory[]

  @@unique([submissionId, url])
  @@index([scrapeStatus])
  @@map("submission_url_scrapes")
}

// Phase 2A: append-only audit trail of every PostVisibility re-scrape pass.
// One row per (urlScrape, checkedAt) — never updated, only inserted. Powers
// the per-URL visibility timeline in the future Phase 3 admin UI.
// See migration 20260418000000_add_visibility_recheck for the DDL.
model SubmissionUrlScrapeHistory {
  id                 String          @id @default(uuid())
  urlScrapeId        String
  submissionId       String
  url                String
  channel            SocialChannel
  format             PostFormat
  scrapeStatus       UrlScrapeStatus
  scrapeResult       Json?
  verificationChecks Json?
  errorMessage       String?
  checkedAt          DateTime        @default(now())

  urlScrape  SubmissionUrlScrape @relation(fields: [urlScrapeId], references: [id], onDelete: Cascade)
  submission Submission          @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([urlScrapeId])
  @@index([submissionId])
  @@index([checkedAt])
  @@map("submission_url_scrape_histories")
}

model Payout {
  id                 String       @id @default(uuid())
  submissionId       String       @unique
  amount             Decimal      @db.Decimal(12, 2)
  currency           Currency     @default(ZAR)
  status             PayoutStatus @default(NOT_PAID)
  paidAt             DateTime?
  proofOfPaymentUrl  String?
  proofOfPaymentName String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("payouts")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String
  actorRole   UserRole
  action      String
  entityType  String
  entityId    String
  beforeState Json?
  afterState  Json?
  reason      String?  @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())

  // Relations
  actor User @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model FileUpload {
  id           String   @id @default(uuid())
  submissionId String
  userId       String
  fileName     String
  fileUrl      String
  mimeType     String
  fileSize     Int
  createdAt    DateTime @default(now())

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  uploadedBy User       @relation("FileUploader", fields: [userId], references: [id], onDelete: Restrict)

  @@index([submissionId])
  @@index([userId])
  @@map("file_uploads")
}

model BrandAsset {
  id        String   @id @default(uuid())
  bountyId  String
  userId    String
  fileName  String
  fileUrl   String
  mimeType  String
  fileSize  Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  bounty     Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("BrandAssetUploader", fields: [userId], references: [id], onDelete: Restrict)

  @@index([bountyId])
  @@index([userId])
  @@map("brand_assets")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string, boolean, number, json
  updatedAt DateTime @updatedAt
  updatedBy String? // userId of admin who last changed it

  @@map("system_settings")
}

// ─────────────────────────────────────
// Dispute Models
// ─────────────────────────────────────

model Dispute {
  id                String             @id @default(uuid())
  disputeNumber     String             @unique // DSP-000001
  category          DisputeCategory
  status            DisputeStatus      @default(DRAFT)
  reason            DisputeReason
  description       String             @db.Text
  desiredOutcome    String             @db.Text
  submissionId      String
  bountyId          String
  openedByUserId    String
  openedByRole      UserRole
  brandId           String             @map("organisationId")
  assignedToUserId  String?
  resolutionType    DisputeResolution?
  resolutionSummary String?            @db.Text
  resolvedByUserId  String?
  resolvedAt        DateTime?
  escalatedAt       DateTime?
  responseDeadline  DateTime?
  relatedDisputeId  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  submission     Submission             @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  openedBy       User                   @relation("DisputeFiler", fields: [openedByUserId], references: [id], onDelete: Restrict)
  assignedTo     User?                  @relation("DisputeAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  resolvedBy     User?                  @relation("DisputeResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  relatedDispute Dispute?               @relation("DisputeChain", fields: [relatedDisputeId], references: [id], onDelete: SetNull)
  childDisputes  Dispute[]              @relation("DisputeChain")
  messages       DisputeMessage[]
  evidence       DisputeEvidence[]
  statusHistory  DisputeStatusHistory[]

  @@index([submissionId])
  @@index([bountyId])
  @@index([openedByUserId])
  @@index([brandId])
  @@index([assignedToUserId])
  @@index([status])
  @@index([category])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([resolvedByUserId])
  @@index([relatedDisputeId])
  @@map("disputes")
}

model DisputeMessage {
  id           String             @id @default(uuid())
  disputeId    String
  authorUserId String
  authorRole   UserRole
  messageType  DisputeMessageType @default(COMMENT)
  content      String             @db.Text
  isInternal   Boolean            @default(false)
  createdAt    DateTime           @default(now())

  // Relations
  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([disputeId])
  @@index([authorUserId])
  @@index([createdAt])
  @@map("dispute_messages")
}

model DisputeEvidence {
  id               String       @id @default(uuid())
  disputeId        String
  uploadedByUserId String
  evidenceType     EvidenceType
  fileUrl          String?
  url              String?
  fileName         String?
  mimeType         String?
  fileSize         Int?
  description      String?      @db.VarChar(500)
  createdAt        DateTime     @default(now())

  // Relations
  dispute    Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([disputeId])
  @@index([uploadedByUserId])
  @@map("dispute_evidence")
}

model DisputeStatusHistory {
  id              String         @id @default(uuid())
  disputeId       String
  fromStatus      DisputeStatus?
  toStatus        DisputeStatus
  changedByUserId String
  changedByRole   UserRole
  note            String?        @db.Text
  createdAt       DateTime       @default(now())

  // Relations
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([disputeId])
  @@index([createdAt])
  @@index([changedByUserId])
  @@map("dispute_status_history")
}

// ─────────────────────────────────────
// Hunter Profile
// ─────────────────────────────────────

model SocialLink {
  id            String        @id @default(uuid())
  userId        String
  platform      SocialChannel
  url           String
  handle        String?
  followerCount Int?
  postCount     Int?
  isVerified    Boolean       @default(false)
  verifiedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
  @@map("social_links")
}

// ─────────────────────────────────────
// Wallet & Ledger
// ─────────────────────────────────────

model Wallet {
  id             String   @id @default(uuid())
  userId         String   @unique
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  pendingBalance Decimal  @default(0) @db.Decimal(12, 2)
  currency       Currency @default(ZAR)
  totalEarned    Decimal  @default(0) @db.Decimal(12, 2)
  totalWithdrawn Decimal  @default(0) @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  transactions WalletTransaction[]
  withdrawals  Withdrawal[]

  @@index([userId])
  @@map("wallets")
}

model WalletTransaction {
  id            String       @id @default(uuid())
  walletId      String
  type          WalletTxType
  amount        Decimal      @db.Decimal(12, 2)
  description   String
  referenceType String // SUBMISSION, WITHDRAWAL, CORRECTION, REFUND
  referenceId   String
  balanceBefore Decimal      @db.Decimal(12, 2)
  balanceAfter  Decimal      @db.Decimal(12, 2)
  createdAt     DateTime     @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([walletId])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model Withdrawal {
  id            String           @id @default(uuid())
  walletId      String
  userId        String
  amount        Decimal          @db.Decimal(12, 2)
  currency      Currency         @default(ZAR)
  method        PayoutMethod
  status        WithdrawalStatus @default(REQUESTED)
  destination   Json
  processedAt   DateTime?
  failureReason String?          @db.Text
  proofUrl      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([walletId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("withdrawals")
}

// ─────────────────────────────────────
// Bounty Access Control
// ─────────────────────────────────────

model BountyApplication {
  id         String                  @id @default(uuid())
  bountyId   String
  userId     String
  status     BountyApplicationStatus @default(PENDING)
  message    String?                 @db.Text
  reviewedBy String?
  reviewNote String?                 @db.Text
  appliedAt  DateTime                @default(now())
  reviewedAt DateTime?

  bounty   Bounty @relation("BountyApplications", fields: [bountyId], references: [id], onDelete: Cascade)
  user     User   @relation("UserApplications", fields: [userId], references: [id])
  reviewer User?  @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])

  @@unique([bountyId, userId])
  @@index([bountyId])
  @@index([userId])
  @@index([status])
  @@index([reviewedBy])
  @@map("bounty_applications")
}

model BountyInvitation {
  id             String                 @id @default(uuid())
  bountyId       String
  userId         String?
  socialPlatform SocialPlatform
  socialHandle   String
  status         BountyInvitationStatus @default(PENDING)
  invitedBy      String
  invitedAt      DateTime               @default(now())
  respondedAt    DateTime?
  expiresAt      DateTime?

  bounty  Bounty @relation("BountyInvitations", fields: [bountyId], references: [id], onDelete: Cascade)
  user    User?  @relation("UserInvitations", fields: [userId], references: [id])
  inviter User   @relation("InvitationCreator", fields: [invitedBy], references: [id])

  @@unique([bountyId, socialPlatform, socialHandle])
  @@index([bountyId])
  @@index([userId])
  @@index([status])
  @@index([invitedBy])
  @@map("bounty_invitations")
}

// ─────────────────────────────────────
// Social Handles (with X/Twitter)
// ─────────────────────────────────────

model UserSocialHandle {
  id               String             @id @default(uuid())
  userId           String
  platform         SocialPlatform
  handle           String
  normalizedHandle String
  profileUrl       String?
  profileImageUrl  String?
  displayName      String?
  followerCount    Int?
  status           SocialHandleStatus @default(PENDING_VALIDATION)
  lastValidatedAt  DateTime?
  validationError  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation("UserSocialHandles", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@unique([platform, normalizedHandle])
  @@index([userId])
  @@index([platform, normalizedHandle])
  @@map("user_social_handles")
}

// ─────────────────────────────────────
// Inbox: Notifications & Conversations
// ─────────────────────────────────────

model Notification {
  id            String           @id @default(uuid())
  userId        String
  type          NotificationType
  title         String
  body          String           @db.Text
  referenceType String?
  referenceId   String?
  actionUrl     String?
  isRead        Boolean          @default(false)
  readAt        DateTime?
  createdAt     DateTime         @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type])
  @@map("notifications")
}

model Conversation {
  id            String              @id @default(uuid())
  context       ConversationContext
  referenceType String?
  referenceId   String?
  subject       String
  createdBy     String
  isArchived    Boolean             @default(false)
  isPriority    Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  creator      User                      @relation("ConversationsCreated", fields: [createdBy], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@index([createdBy])
  @@index([isPriority, updatedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  isMuted        Boolean   @default(false)
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation("ConversationParticipants", fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id              String    @id @default(uuid())
  conversationId  String
  senderId        String
  body            String    @db.Text
  attachmentUrl   String?
  attachmentName  String?
  isSystemMessage Boolean   @default(false)
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessagesSent", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ─────────────────────────────────────
// Subscriptions
// ─────────────────────────────────────

model Subscription {
  id                 String                 @id @default(uuid())
  userId             String?                @unique
  brandId            String?                @unique @map("organisationId")
  entityType         SubscriptionEntityType
  tier               SubscriptionTier       @default(FREE)
  status             SubscriptionStatus     @default(FREE)
  priceAmount        Decimal                @db.Decimal(10, 2)
  currency           Currency               @default(ZAR)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  cancelAtPeriodEnd  Boolean                @default(false)
  gracePeriodEndsAt  DateTime?
  failedPaymentCount Int                    @default(0)
  provider           String?
  providerSubId      String?
  providerCustomerId String?
  metadata           Json                   @default("{}")
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  user     User?                 @relation("UserSubscription", fields: [userId], references: [id])
  brand    Brand?                @relation("BrandSubscription", fields: [brandId], references: [id])
  payments SubscriptionPayment[]

  @@unique([userId, entityType])
  @@unique([brandId, entityType])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([tier])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id                 String                    @id @default(uuid())
  subscriptionId     String
  amount             Decimal                   @db.Decimal(10, 2)
  currency           Currency                  @default(ZAR)
  status             SubscriptionPaymentStatus @default(PENDING)
  provider           String?
  providerPaymentId  String?                   @unique
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  attemptNumber      Int                       @default(1)
  failureReason      String?
  paidAt             DateTime?
  // Plan snapshot (Non-Negotiable #9): tier captured at charge creation time
  // so in-flight transactions are never re-priced on plan change.
  tierSnapshot       SubscriptionTier?
  createdAt          DateTime                  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@map("subscription_payments")
}

// ─────────────────────────────────────
// Double-entry Ledger
// Source: md-files/payment-gateway.md + md-files/financial-architecture.md
// Payment rail: TradeSafe (unified inbound + outbound per ADR 0011).
// ─────────────────────────────────────

// Transaction group header. Idempotency constraint UNIQUE(referenceId, actionType)
// lives here so multi-leg groups work cleanly (Non-Negotiable #2).
model LedgerTransactionGroup {
  id          String   @id @default(uuid())
  referenceId String
  actionType  String
  description String
  auditLogId  String?
  createdAt   DateTime @default(now())

  entries LedgerEntry[]

  @@unique([referenceId, actionType])
  @@index([createdAt])
  @@map("ledger_transaction_groups")
}

// Append-only double-entry ledger (Non-Negotiable #5).
// Amount is always positive; sign is carried by `type`.
model LedgerEntry {
  id                 String            @id @default(uuid())
  transactionGroupId String
  userId             String?
  brandId            String?
  bountyId           String?
  submissionId       String?
  account            LedgerAccount
  type               LedgerEntryType
  amount             BigInt
  currency           Currency          @default(ZAR)
  status             LedgerEntryStatus @default(COMPLETED)
  referenceId        String
  referenceType      String
  actionType         String
  externalReference  String?
  parentEntryId      String?
  clearanceReleaseAt DateTime?
  metadata           Json?
  postedBy           String
  auditLogId         String?
  createdAt          DateTime          @default(now())

  transactionGroup LedgerTransactionGroup @relation(fields: [transactionGroupId], references: [id], onDelete: Restrict)
  user             User?                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  brand            Brand?                 @relation(fields: [brandId], references: [id], onDelete: Restrict)
  bounty           Bounty?                @relation(fields: [bountyId], references: [id], onDelete: Restrict)
  submission       Submission?            @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  parent           LedgerEntry?           @relation("LedgerEntryReversal", fields: [parentEntryId], references: [id], onDelete: Restrict)
  children         LedgerEntry[]          @relation("LedgerEntryReversal")

  @@index([transactionGroupId])
  @@index([userId, account, status])
  @@index([account, createdAt])
  @@index([externalReference])
  @@index([bountyId])
  @@index([submissionId])
  @@index([clearanceReleaseAt, account, status])
  @@map("ledger_entries")
}

// Svix-delivered webhook envelope with dedup constraint (Non-Negotiable #7).
model WebhookEvent {
  id              String          @id @default(uuid())
  provider        WebhookProvider
  externalEventId String
  eventType       String
  status          WebhookStatus   @default(RECEIVED)
  payload         Json
  signatureHeader String?
  svixTimestamp   DateTime?
  receivedAt      DateTime        @default(now())
  processedAt     DateTime?
  errorMessage    String?         @db.Text
  attempts        Int             @default(0)
  result          Json?

  @@unique([provider, externalEventId])
  @@index([provider, eventType, receivedAt])
  @@index([status])
  @@map("webhook_events")
}

// ─────────────────────────────────────
// TradeSafe (unified inbound + outbound rail per ADR 0011)
// One TradeSafeTransaction per Bounty. Allocations model the per-hunter
// payout legs. Integer minor units throughout (Financial Non-Negotiable #4);
// conversion to/from TradeSafe's ZAR decimal happens at the adapter boundary
// via toCents / toZar in tradesafe-graphql.operations.ts.
// ─────────────────────────────────────

model TradeSafeTransaction {
  id                     String                    @id @default(uuid())
  bountyId               String                    @unique
  tradeSafeTransactionId String                    @unique
  // Merchant-side reference sent to TradeSafe (`reference` field). Echoed
  // back on webhooks for correlation. Nullable because some legacy/mock
  // rows may not have set it.
  reference              String?
  state                  TradeSafeTransactionState @default(CREATED)
  // Integer minor units (cents). Non-Negotiable #4 — never store as float.
  totalValueCents        BigInt
  currency               Currency                  @default(ZAR)
  // Hosted-checkout URL from `checkoutLink` mutation. Nullable because it's
  // generated after the initial transactionCreate — populated on a
  // subsequent call.
  checkoutUrl            String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  bounty      Bounty                @relation(fields: [bountyId], references: [id], onDelete: Restrict)
  allocations TradeSafeAllocation[]

  @@index([state])
  @@map("tradesafe_transactions")
}

model TradeSafeAllocation {
  id                    String                   @id @default(uuid())
  transactionId         String
  tradeSafeAllocationId String                   @unique
  title                 String
  // Integer minor units (cents). Sum of allocations equals parent
  // transaction.totalValueCents modulo fee-side allocations.
  valueCents            BigInt
  state                 TradeSafeAllocationState @default(CREATED)
  daysToDeliver         Int
  daysToInspect         Int
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  transaction TradeSafeTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([state])
  @@map("tradesafe_allocations")
}

// Audit row per scheduled-job execution (observability for Phase 2+ jobs).
model JobRun {
  id          String       @id @default(uuid())
  jobName     String
  status      JobRunStatus
  startedAt   DateTime     @default(now())
  finishedAt  DateTime?
  itemsSeen   Int          @default(0)
  itemsOk     Int          @default(0)
  itemsFailed Int          @default(0)
  details     Json?
  error       String?      @db.Text

  @@index([jobName, startedAt])
  @@map("job_runs")
}

model Refund {
  id                   String         @id @default(uuid())
  bountyId             String
  submissionId         String?
  scenario             RefundScenario
  state                RefundState    @default(REQUESTED)
  amountCents          BigInt
  reason               String         @db.Text
  requestedByUserId    String
  approvedByUserId     String?
  approvalNote         String?
  dualApprovalByUserId String?
  kbEntryId            String?
  transactionGroupId   String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  bounty         Bounty      @relation(fields: [bountyId], references: [id], onDelete: Restrict)
  submission     Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  requestedBy    User        @relation("RefundRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  approvedBy     User?       @relation("RefundApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  dualApprovedBy User?       @relation("RefundDualApprover", fields: [dualApprovalByUserId], references: [id], onDelete: SetNull)

  @@index([bountyId])
  @@index([state])
  @@index([scenario])
  @@map("refunds")
}

// KB automation (Phase 4). Reconciliation findings and webhook failures
// write/update rows here; signature-match dedup via (category, signature).
model RecurringIssue {
  id          String    @id @default(uuid())
  category    String
  signature   String
  title       String
  severity    String    @default("warning") // info | warning | critical
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  occurrences Int       @default(1)
  openedBy    String?
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  rootCause   String?   @db.Text
  mitigation  String?   @db.Text
  kbEntryRef  String?
  metadata    Json?

  // Phase 4 exit criterion: when a resolved KB entry recurs within 90d of
  // resolution, the entry is auto-flagged as an "Ineffective Fix" by
  // KbService.flagIneffectiveFix(). Surfaced on admin/finance/insights.
  ineffectiveFix       Boolean   @default(false)
  ineffectiveFlaggedAt DateTime?
  ineffectiveFlaggedBy String? // actorId of the auto-flagger (system actor)

  @@unique([category, signature])
  @@index([resolved, lastSeenAt])
  @@map("recurring_issues")
}
